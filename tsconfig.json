{
  "compilerOptions": {
    "allowJs": false,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2022",
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": [
    "server.ts",
    "server/**/*.ts",
    "src/**/*.ts",
    "test/**/*.ts",
    "testing/**/*.ts",
    "vite.config.js",
    "eslint.config.js"
  ]
}
